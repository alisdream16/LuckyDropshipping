# Railway otomatik atar
PORT=3000

# Railway domain'iniz (deploy sonrası güncelleyin)
# Örnek: https://luckydropshipping-production.up.railway.app
BASE_URL=https://your-app.up.railway.app

# AliExpress Open Platform (console.aliexpress.com)
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_APP_SECRET=your_app_secret

# Callback URL - AliExpress konsolunda AYNI değeri girin:
# ${BASE_URL}/api/aliexpress/callback
ALIEXPRESS_REDIRECT_URI=https://your-app.up.railway.app/api/aliexpress/callback

# eBay Developer Program (developer.ebay.com)
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_SANDBOX=false
